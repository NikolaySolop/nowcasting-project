    {
      "source_code": "EXCHANGERATES_URALS_USD_DAILY",
      "source_name": "ExchangeRates.org.uk URALS/USD daily close",
      "source_type": "web",
      "adapter_name": "exchangerates",
      "enabled": false,
      "schedule_cron": "30 1 * * *",
      "scrape": {
        "url": "https://www.exchangerates.org.uk/commodities/URALS-USD-history.html",
        "method": "POST",
        "parser": "json",
        "series_code": "EXCHANGERATES:URALSUSD:DAILY",
        "extra": {
          "mode": "history_daily",
          "pair": "URALS/USD",
          "ajax": "hist",
          "streaming_persistence": true,
          "history_post": true,
          "history_form_encoding": "multipart",
          "browser_headers": true,
          "max_range_years": 5,
          "per": 90,
          "history_delay_min_seconds": 4.5,
          "history_delay_max_seconds": 11,
          "history_page_retries": 6,
          "history_retry_delay_seconds": 15,
          "from_param": "from",
          "to_param": "to",
          "page_param": "page",
          "per_param": "per",
          "referer": "https://www.exchangerates.org.uk/commodities/URALS-USD-history.html"
        },
        "start_date": "01.01.2015"
      },
      "series": [
        {
          "series_code": "EXCHANGERATES:URALSUSD:DAILY",
          "series_name": "Urals crude oil, USD/bbl, daily close"
        }
      ],
      "metadata": {
        "note": "Uses the POST multipart history XHR JSON endpoint and splits requests into max 5-year date windows. Requires EXCHANGERATES_AJAX_NONCE and usually EXCHANGERATES_COOKIE from a browser session."
      }
    },
    {
      "source_code": "EXCHANGERATES_URALS_USD_LIVE_HTML",
